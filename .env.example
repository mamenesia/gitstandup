# --- AI summarization ---
SUMPOD_API_KEY=***

# --- GitHub OAuth (required to use the app) ---
# Create an OAuth App at https://github.com/settings/developers
# Homepage URL:  https://your-domain
# Callback URL:  https://your-domain/api/auth/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Must match the Callback URL above (used by the OAuth flow).
OAUTH_REDIRECT_URL=https://your-domain/api/auth/callback

# Base URL of your deployment (for redirects after login/logout).
APP_BASE_URL=https://your-domain

# --- Session cookie encryption ---
# 32+ random characters. Generate with: openssl rand -hex 32
SESSION_SECRET=

# --- Standup window ---
# How many days of history to summarize. Default 7 (weekly).
STANDUP_WINDOW_DAYS=7
